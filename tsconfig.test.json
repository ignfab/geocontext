{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": [
      "vitest/globals",
      "node"
    ]
  },
  "include": [
    "./src/**/*",
    "./test/**/*",
    "./vitest*.mts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
