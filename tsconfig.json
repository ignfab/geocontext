{
    "compilerOptions": {
        "outDir": "./dist/",
        "rootDir": "./src",
        "noImplicitAny": true,
        "moduleResolution": "NodeNext",
        "sourceMap": true,
        "declaration": true,
        "module": "NodeNext",
        "target": "ESNext",
        "lib": [ "es2015" ],
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "allowJs": false,
        "esModuleInterop": true
    },
    "include": [
        "./src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}
